# One of these is required for the orchestrator to call an LLM.
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# Model + limits
ATLAS_MODEL=claude-sonnet-4-5
ATLAS_MAX_TOKENS=2048
ATLAS_MAX_STEPS=16
ATLAS_TOKEN_BUDGET=8000

# Local warehouse
ATLAS_DB_PATH=data/warehouse.duckdb

# Durable multi-turn memory (set ATLAS_PERSIST_MEMORY=0 for ephemeral)
ATLAS_SESSIONS_DB=data/sessions.db
ATLAS_PERSIST_MEMORY=1
